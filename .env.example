# Timegrip / ADFS
TIMEGRIP_BASE_URL=https://yourcompany.timeplan-software.com
SALLING_EMAIL=your_email@company.com
SALLING_PASSWORD=your_ad_password

# Google Calendar
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret
GOOGLE_REFRESH_TOKEN=your_refresh_token
CALENDAR_NAME=Work

# Sync settings
SYNC_AHEAD_WEEKS=12
SYNC_LOOKBACK_WEEKS=4

# Pay config (DKK)
HOURLY_RATE=0.00
EVENING_SUPPLEMENT=0.00
SATURDAY_SUPPLEMENT=0.00
SUNDAY_SUPPLEMENT=0.00
EVENING_CUTOFF_HOUR=18
AM_BIDRAG_PCT=8.0
TAX_PCT=0.0
EMPLOYEE_PENSION_PCT=0.0
EMPLOYER_PENSION_PCT=0.0
ATP_DKK=0.0
KLUB_DKK=0.0
FRITVALG_PCT=0.0
FERIEFRI_PCT=0.0
ADVANCE_NOTICE_DAYS=14

# Web report (optional)
REPORT_PASSWORD=your_report_password
REPORT_SALT=your_random_salt_string
SITE_LABEL=yoursite.example.com

# MySQL (optional, used with --save)
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_DATABASE=your_db_name
