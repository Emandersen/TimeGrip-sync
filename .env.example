# Salling Group / Timegrip credentials
SALLING_EMAIL=abc123@sallinggroup.com
SALLING_PASSWORD=your_ad_password

# Google OAuth2 — from Google Cloud Console (timegripScrap project)
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret

# Obtained after first OAuth login (run sync_calendar.py once locally,
# then copy refresh_token from token.json)
GOOGLE_REFRESH_TOKEN=your_refresh_token
